# =============================================================================
# sessiond .env.example — environment variables that sessiond reads
# =============================================================================
#
# Two flavours are honoured. The legacy SUPERSET_* set is checked first inside
# each getter; the modern APP_SESSIOND_* set goes through gosdk's viper layer
# with AutomaticEnv and the APP_ prefix, so the path is encoded with `_`.
#
# Verified by probe 2026-07-20:
#   - APP_FLATKEY                       works (no path component)
#   - APP_SESSIOND_SUMMARIZER_MODEL     works (nested key, `_` = `.`)
#   - SUPERSET_SUMMARIZER_MODEL         works (legacy single-source override)
# =============================================================================

# ── Required for LLM summarization ───────────────────────────────────────────
# Without this key, provider=auto falls back to heuristic and the LLM path is
# never exercised. Symptom: every turn has source="heuristic" in the JSONL
# even though the hook log prints summarizer=llm.
GOOGLE_API_KEY=AIza...

# ── Modern (APP_-prefixed) ───────────────────────────────────────────────────
# Preferred for new deployments. Layered on top of YAML/JSON files.
APP_SESSIOND_SUMMARIZER_PROVIDER=auto
APP_SESSIOND_SUMMARIZER_MODEL=gemma-4-26b-a4b-it

# Override transcript locations. Leave commented to use agent defaults.
# APP_SESSIOND_AGENTS_CLAUDE_TRANSCRIPTS_DIR=/Users/me/work/transcripts
# APP_SESSIOND_AGENTS_CODEX_SESSIONS_DIR=/Users/me/work/codex-sessions

# ── Legacy (SUPERSET_-prefixed, single-source) ──────────────────────────────
# Kept for backwards compatibility; checked before APP_ equivalents.
# SUPERSET_SUMMARIZER=auto
# SUPERSET_SUMMARIZER_MODEL=gemma-4-26b-a4b-it
# SUPERSET_CODEX_SESSIONS_DIR=/Users/me/work/codex-sessions
